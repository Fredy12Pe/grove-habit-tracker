{
  "expo": {
    "name": "grove",
    "slug": "grove",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcon.appiconset/icon-ios-1024x1024.png",
    "scheme": "grove",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.groveHabits.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Grove needs access to your local network to connect to the Metro development server.",
        "NSPhotoLibraryUsageDescription": "Grove uses your photo library so you can set a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/AppIcon.appiconset/icon-ios-1024x1024.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/AppIcon.appiconset/icon-mac-128x128.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Grove uses your photo library so you can set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.groveHabits.app.widgets",
          "groupIdentifier": "group.com.groveHabits.app",
          "widgets": [
            {
              "name": "DailyStatusWidget",
              "displayName": "Today's Habits",
              "description": "Shows today's habit completion at a glance.",
              "supportedFamilies": ["systemSmall"]
            },
            {
              "name": "WeeklyGrowthWidget",
              "displayName": "Weekly Growth",
              "description": "Shows your plants growing through the week.",
              "supportedFamilies": ["systemLarge"]
            }
          ]
        }
      ],
      [
        "./plugins/withWidgetDeepLink",
        {
          "url": "grove:///(tabs)/habits"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
