{
  "expo": {
    "name": "Grove",
    "slug": "grove",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcon.appiconset/icon-ios-1024x1024.png",
    "scheme": "grove",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.groveHabits.app",
      "appleTeamId": "78AKYC98Z3",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.groveHabits.app",
          "group.com.groveHabits.app"
        ]
      },
      "infoPlist": {
        "CFBundleDisplayName": "Grove",
        "NSLocalNetworkUsageDescription": "Grove needs access to your local network to connect to the Metro development server.",
        "NSPhotoLibraryUsageDescription": "Grove uses your photo library so you can set a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/AppIcon.appiconset/icon-ios-1024x1024.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3FBDE",
      "dark": {
        "image": "./assets/images/splash-icon.png",
        "backgroundColor": "#F3FBDE"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/AppIcon.appiconset/icon-mac-128x128.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Grove uses your photo library so you can set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F3FBDE",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#F3FBDE"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "@bacons/apple-targets",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.groveHabits.app.widgets",
                  "targetName": "GroveWidgets",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.groveHabits.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "3ea971a9-b020-4461-a09b-0e8ff70b34d8"
      }
    }
  }
}
