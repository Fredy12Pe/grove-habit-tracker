# Copy to `.env` in the project root. Restart `npx expo start` after changing.
#
# Physical device can't load JS (e.g. "failed to connect to http://192.168.x.x:8081")?
# Same Wi‑Fi as the Mac, VPN off, iOS Settings → Grove → Local Network ON, and macOS
# Firewall must allow Node on port 8081. Or use: npm run start:tunnel (ngrok; slower but works off-LAN).
# Get values from: Supabase dashboard → Project Settings → API.
# Use EXPO_PUBLIC_* only — Next.js-style NEXT_PUBLIC_* is not loaded by Expo.
#
# Also add your app redirect URL under Authentication → URL Configuration → Redirect URLs
# (e.g. grove://auth/callback) so Google OAuth and email confirmation links work.
#
# Sign in with Apple (native iOS): Supabase → Authentication → Providers → Apple → Client IDs
# must include your iOS bundle ID (see app.json ios.bundleIdentifier), e.g. com.groveHabits.app
# — comma-separated with your Services ID if you use web Apple login too. Without it, Supabase
# returns: "unacceptable audience in id_token".

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
