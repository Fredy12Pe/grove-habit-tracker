    "ios": "expo run:ios",
    "prebuild:ios": "expo prebuild --platform ios",
    "ios:go": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "generate-widget-plants": "node ./scripts/generate-widget-plant-images.js",
    "sync-widget-small-assets": "node ./scripts/sync-widget-small-assets.js",
    "postinstall": "node ./scripts/generate-widget-plant-images.js && node ./scripts/sync-widget-small-assets.js"
  },
